<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="orhestra.coordinator.ui.CloudController">

    <left>
        <VBox spacing="12" prefWidth="420" styleClass="cloud-sidebar">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

            <!-- ====== КОНФИГУРАЦИЯ (INI) ====== -->
            <TitledPane text="Конфигурация (INI)" expanded="true" collapsible="false" styleClass="section-pane">
                <content>
                    <VBox spacing="10">
                        <padding><Insets top="8" right="4" bottom="8" left="4"/></padding>

                        <!-- Recent INI ComboBox -->
                        <Label text="Недавние конфиги:" styleClass="muted"/>
                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <ComboBox fx:id="recentIniCombo" promptText="Выберите из списка…" HBox.hgrow="ALWAYS"
                                      maxWidth="1.7976931348623157E308"/>
                            <Button text="✕" onAction="#handleRemoveRecent" styleClass="btn-icon">
                                <tooltip><Tooltip text="Удалить из списка"/></tooltip>
                            </Button>
                            <Button text="🗑" onAction="#handleClearRecent" styleClass="btn-icon">
                                <tooltip><Tooltip text="Очистить список"/></tooltip>
                            </Button>
                        </HBox>

                        <Separator/>

                        <!-- INI Path + FileChooser -->
                        <Label text="Путь к INI:" styleClass="muted"/>
                        <HBox spacing="6">
                            <TextField fx:id="iniPathField" promptText="/path/to/config.ini"
                                       HBox.hgrow="ALWAYS"/>
                            <Button text="📂" onAction="#handleChooseIni" styleClass="btn-icon">
                                <tooltip><Tooltip text="Выбрать файл…"/></tooltip>
                            </Button>
                        </HBox>

                        <Button text="Загрузить INI" onAction="#handleLoadIni" styleClass="btn-primary"
                                maxWidth="1.7976931348623157E308"/>
                    </VBox>
                </content>
            </TitledPane>

            <!-- ====== ПРОВЕРКИ ОКРУЖЕНИЯ ====== -->
            <TitledPane text="Проверки окружения" expanded="true" styleClass="section-pane">
                <content>
                    <VBox spacing="10">
                        <padding><Insets top="8" right="4" bottom="8" left="4"/></padding>

                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="Облако:" minWidth="100"/>
                            <Label fx:id="dotCloud" text="●" style="-fx-text-fill: #999999; -fx-font-size: 16;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="btnCheckCloud" text="Проверить" onAction="#handleCheckCloud"/>
                        </HBox>

                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="OpenVPN AS:" minWidth="100"/>
                            <Label fx:id="dotOvpn" text="●" style="-fx-text-fill: #999999; -fx-font-size: 16;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="btnOvpnOn"  text="Вкл" onAction="#handleOvpnOn"/>
                            <Button fx:id="btnOvpnOff" text="Выкл" onAction="#handleOvpnOff"/>
                        </HBox>

                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="VPN (tun):" minWidth="100"/>
                            <Label fx:id="dotVpn" text="●" style="-fx-text-fill: #999999; -fx-font-size: 16;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="btnCheckVpn" text="Проверить" onAction="#handleCheckVpn"/>
                        </HBox>

                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="Координатор:" minWidth="100"/>
                            <Label fx:id="dotCoord" text="●" style="-fx-text-fill: #999999; -fx-font-size: 16;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="btnStartCoordinator" text="Запустить" onAction="#handleStartCoordinator"/>
                            <Button fx:id="btnStopCoordinator"  text="Остановить" onAction="#handleStopCoordinator"/>
                        </HBox>

                        <Separator/>

                        <!-- Информационные лейблы: VPN IP и адрес координатора -->
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="VPN IP:" minWidth="100" styleClass="muted"/>
                            <Label fx:id="labelVpnIp" text="—" style="-fx-font-family: monospace; -fx-font-size: 13;"/>
                        </HBox>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="Координатор:" minWidth="100" styleClass="muted"/>
                            <Label fx:id="labelCoordUrl" text="—" style="-fx-font-family: monospace; -fx-font-size: 13;"/>
                        </HBox>
                    </VBox>
                </content>
            </TitledPane>

            <!-- ====== ЛОГ КООРДИНАТОРА ====== -->
            <TitledPane text="Координатор — лог" expanded="false" styleClass="section-pane">
                <content>
                    <VBox spacing="6">
                        <padding><Insets top="4" right="4" bottom="4" left="4"/></padding>
                        <TextArea fx:id="coordLogArea" prefRowCount="8" wrapText="true" editable="false"
                                  styleClass="log-area"/>
                        <HBox alignment="CENTER_RIGHT">
                            <Button text="Очистить" onAction="#handleClearCoordLog" styleClass="btn-icon"/>
                        </HBox>
                    </VBox>
                </content>
            </TitledPane>

            <!-- Status bar -->
            <Separator/>
            <Label fx:id="statusLabel" text="Загрузите INI-конфиг для начала работы"
                   styleClass="muted" wrapText="true"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="10">
            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

            <HBox spacing="8" alignment="CENTER_LEFT">
                <Button text="Список ВМ" onAction="#handleListInstances"/>
                <Button fx:id="btnCreateSpot" text="Создать SPOT" onAction="#handleCreateSpot"
                        disable="true" styleClass="btn-primary"/>
                <Button text="Удалить выбранные" onAction="#handleDeleteSelected"/>
                <ProgressIndicator fx:id="createSpinner" prefWidth="22" prefHeight="22"
                                   visible="false" managed="false"/>
                <Label fx:id="createProgressLabel" text="" styleClass="muted"
                       visible="false" managed="false"/>
            </HBox>

            <TableView fx:id="instancesTable" VBox.vgrow="ALWAYS">
                <placeholder>
                    <Label text="Нажмите «Список ВМ» для загрузки" styleClass="muted"
                           style="-fx-font-size: 14;"/>
                </placeholder>
                <columns>
                    <TableColumn fx:id="colId"       text="ID"        prefWidth="200"/>
                    <TableColumn fx:id="colName"     text="Имя"       prefWidth="160"/>
                    <TableColumn fx:id="colZone"     text="Зона"      prefWidth="100"/>
                    <TableColumn fx:id="colStatus"   text="Статус"    prefWidth="100"/>
                    <TableColumn fx:id="colIP"       text="IP"        prefWidth="140"/>
                    <TableColumn fx:id="colCreated"  text="Создан"    prefWidth="160"/>
                    <TableColumn fx:id="colPreempt"  text="SPOT?"     prefWidth="70"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
